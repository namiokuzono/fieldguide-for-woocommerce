---
/**
 * Soft editorial callout card — magazine sidebar, not docs aside.
 *   field → "From the field"     — anecdotes from real support cases
 *   edge  → "Edge case"          — unusual inputs
 *   gap   → "Known gap"          — things WooCommerce doesn't handle
 *   tip   → "Worth knowing"      — insights / shortcuts
 *   info  → "Note"               — general clarification
 */
interface Props {
  type: 'field' | 'edge' | 'gap' | 'tip' | 'info';
  label?: string;
}

const { type, label } = Astro.props;

const defaultLabels: Record<string, string> = {
  field: 'From the field',
  edge: 'Edge case',
  gap: 'Known gap',
  tip: 'Worth knowing',
  info: 'Note',
};

const text = label ?? defaultLabels[type];
---

<aside class={`fg-callout fg-callout-${type}`}>
  {text && <span class="fg-callout-label">{text}</span>}
  <div class="fg-callout-body"><slot /></div>
</aside>
