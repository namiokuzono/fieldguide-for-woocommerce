---
/**
 * Friction / setup-difficulty indicator.
 * Levels 1–5, with humanized labels so merchants can read them at a glance.
 * Styling lives in src/styles/app.css so palette + dark mode apply.
 */
interface Props {
  level: 1 | 2 | 3 | 4 | 5;
  label?: string;
}

const { level, label } = Astro.props;

const defaultLabels: Record<number, string> = {
  1: 'Easy — anyone can do this',
  2: 'Straightforward',
  3: 'Takes a weekend',
  4: 'Get help if you are new',
  5: 'Hire a developer',
};

const text = label ?? defaultLabels[level];
---

<span
  class={`fg-friction fg-friction-${level}`}
  aria-label={`Setup difficulty ${level} of 5: ${text}`}
  title={`Setup difficulty: ${text}`}
>
  <span class="fg-friction-dots" aria-hidden="true">
    {[1, 2, 3, 4, 5].map((i) => (
      <span class={`fg-friction-dot${i <= level ? ' filled' : ''}`}></span>
    ))}
  </span>
  <span class="fg-friction-text">{text}</span>
</span>
